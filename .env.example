# Database (PostgreSQL - Supabase/Neon)
DATABASE_URL="postgresql://username:password@hostname:5432/database_name?schema=public"

# NextAuth
NEXTAUTH_SECRET="replace-with-strong-secret"
NEXTAUTH_URL="http://localhost:3000"

# Public App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional seed endpoint guard.
# In production, POST/GET /api/seed requires this value in the x-seed-token header.
SEED_DATABASE_TOKEN=""

# Resend (optional; console fallback without key)
RESEND_API_KEY=""

# Upstash Redis (optional, production rate limiting)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Vercel Blob (optional, production file uploads)
BLOB_READ_WRITE_TOKEN=""

# Vercel Deployment Protection bypass token (optional, for protected preview checks)
VERCEL_PROTECTION_BYPASS=""

# Demo/staff seeding overrides (optional)
SEED_STAFF_PASSWORD=""
SEED_ADMIN_EMAIL="admin@mama-tu.health"
SEED_PROVIDER_EMAIL="provider@mama-tu.health"
SEED_RECEPTION_EMAIL="reception@mama-tu.health"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
