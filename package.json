{
  "name": "mamamtu",
  "version": "1.0.0",
  "description": "Maternal & Newborn Health Support System - A comprehensive healthcare dashboard for managing maternal and newborn health services",
  "author": "Kadioko",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "lint": "eslint . --quiet",
    "lint:all": "eslint .",
    "start": "next start",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "node scripts/ensure-staff-users.js && node scripts/seed-education.js && node scripts/seed-demo-clinical.js",
    "seed:staff": "node scripts/ensure-staff-users.js",
    "prisma:migrate:postgres": "node scripts/migrate-to-postgres.js",
    "docker:postgres": "docker-compose -f docker-compose.postgres.yml up",
    "docker:postgres:down": "docker-compose -f docker-compose.postgres.yml down",
    "db:backup": "node scripts/backup-database.js",
    "db:restore": "node scripts/restore-database.js",
    "postinstall": "prisma generate"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
